# Backend Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Option 1: Local PostgreSQL (Docker)
DATABASE_URL=postgresql://tarot:tarot123@localhost:5432/tarot_dev

# Option 2: Local SQLite (fallback, no Docker needed)
# DATABASE_URL=sqlite:///./tarot.db

# Option 3: Supabase Production (for production only!)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ============================================
# OPENROUTER API CONFIGURATION
# ============================================

# Required: Get from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model selection - using GPT-4o-mini for better accuracy
OPENROUTER_MODEL=openai/gpt-4o-mini

# Other options:
# Free: google/gemma-2-9b-it:free
# Free: meta-llama/llama-3.2-3b-instruct:free
# Better: anthropic/claude-3-haiku

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Your frontend URL
APP_URL=http://localhost:3000

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting (requests per minute)
RATE_LIMIT_REQUESTS_PER_MINUTE=5

# Session timeout in minutes (default: 30, set to 1440 for 24 hours testing)
SESSION_TIMEOUT_MINUTES=1440

# ============================================
# OPTIONAL: ADVANCED SETTINGS
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Port to run the server (default: 8000)
PORT=8000
